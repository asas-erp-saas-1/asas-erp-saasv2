# ==============================================================================
# ASAS ERP - ENV CONFIGURATION (PRODUCTION TEMPLATE)
# ==============================================================================

# SUPABASE CONFIG
# Required: Retrieve from Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVER SIDE ONLY - CRITICAL SECURITY
# Required: Used for internal admin actions bypassing RLS (e.g. initial onboarding)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# STRIPE CONFIG (PAYMENTS / BILLING)
# Optional: Required if using billing features
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AI INTEGRATION (GEMINI)
# Optional: Required for AI-powered lead scoring/summaries
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-key

# UPSTASH REDIS
# Required: Rate limiting and caching
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# SECURITY
# Required: Strong random string (32+ chars) for cron/internal auth
CRON_SECRET=your-secure-cron-secret

# ANALYTICS
# Optional: Google Analytics Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ENVIRONMENT
NODE_ENV=development
